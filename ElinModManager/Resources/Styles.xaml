<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Defined Colours -->
    <Color x:Key="LightColour">#3d3d4c</Color>
    <Color x:Key="DarkColour">#2a2b34</Color>
    <Color x:Key="ItemColour">#4a4a5e</Color>
    <Color x:Key="ItemHover">#727290</Color>
    <Color x:Key="TitleBlue">#4e38c9</Color>
    <Color x:Key="HoverColour">#33FFFFFF</Color>
    <Color x:Key="PressColour">#66FFFFFF</Color>
    <SolidColorBrush x:Key="LightBrush" Color="{StaticResource LightColour}" />
    <SolidColorBrush x:Key="DarkBrush" Color="{StaticResource DarkColour}" />
    <SolidColorBrush x:Key="ItemBrush" Color="{StaticResource ItemColour}" />
    <SolidColorBrush x:Key="ItemHoverBrush" Color="{StaticResource ItemHover}" />
    <SolidColorBrush x:Key="TitleBrush" Color="{StaticResource TitleBlue}" />
    <SolidColorBrush x:Key="MenuHoverBrush" Color="{StaticResource HoverColour}" />
    <SolidColorBrush x:Key="MenuPressBrush" Color="{StaticResource PressColour}" />


    <Style x:Key="HeaderBg" TargetType="{x:Type Control}">
        <Setter Property="Background" Value="{StaticResource TitleBrush}" />
    </Style>
    <!-- Light Backgrounds - requires Style="{StaticResource X_KEY_NAME}" -->
    <Style x:Key="LightBg" TargetType="{x:Type Control}">
        <Setter Property="Background" Value="{StaticResource LightBrush}" />
    </Style>
    <Style x:Key="LightBgBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource LightBrush}" />
    </Style>
    <Style x:Key="LightBgPanel" TargetType="{x:Type Panel}">
        <Setter Property="Background" Value="{StaticResource LightBrush}" />
    </Style>
    <!-- Dark Backgrounds - requires Style="{StaticResource X_KEY_NAME} -->
    <Style x:Key="DarkBg" TargetType="{x:Type Control}">
        <Setter Property="Background" Value="{StaticResource DarkBrush}" />
    </Style>
    <Style x:Key="DarkBgBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource DarkBrush}" />
    </Style>
    <Style x:Key="DarkBgPanel" TargetType="{x:Type Panel}">
        <Setter Property="Background" Value="{StaticResource DarkBrush}" />
    </Style>

    <!-- All Text -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="White" />
    </Style>
    <Style x:Key="PaddedRows" TargetType="Grid">
        <Style.Resources>
            <Style TargetType="Border">
                <Setter Property="Margin" Value="1,5" />
            </Style>
        </Style.Resources>
    </Style>
    <Style x:Key="PaddedRowsDark" TargetType="Grid">
        <Style.Resources>
            <Style TargetType="Border"
                   BasedOn="{StaticResource DarkBgBorder}">
                <Setter Property="Margin" Value="1,5" />
            </Style>
        </Style.Resources>
    </Style>

    <!-- Menu Bar -->
    <Style TargetType="Menu">
        <Setter Property="Background" Value="{StaticResource DarkBrush}"/>
        <Style.Resources>
            <Style TargetType="MenuItem">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="8,4"/>
                <Setter Property="OverridesDefaultStyle" Value="True"/>

                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="MenuItem">
                            <Grid>
                                <!-- Header -->
                                <Border x:Name="Bd"
                                        Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter
                                        ContentSource="Header"
                                        VerticalAlignment="Center"/>
                                </Border>
                                <!-- Submenu -->
                                <Popup x:Name="PART_Popup"
                                       Placement="Bottom"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       IsOpen="{TemplateBinding IsSubmenuOpen}">
                                    <Border Background="{StaticResource DarkBrush}"
                                                    BorderThickness="0">
                                        <ScrollViewer VerticalScrollBarVisibility="Disabled"
                                                      HorizontalScrollBarVisibility="Disabled">
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>

                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd"
                                            Property="Background"
                                            Value="{StaticResource MenuHoverBrush}"/>
                                </Trigger>

                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd"
                                            Property="Background"
                                            Value="{StaticResource MenuPressBrush}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </Style.Resources>
    </Style>
    
    <Style x:Key="PopoutHeaderMenuItemStyle" TargetType="MenuItem">
        <!-- Hide the normal header completely -->
        <Setter Property="HeaderTemplate">
            <Setter.Value>
                <DataTemplate>
                    <TextBlock Visibility="Collapsed"/>
                </DataTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Margin" Value="4" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Grid>
                        <!-- Icon always visible -->
                        <ContentPresenter
                            ContentSource="Icon"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                        <!-- Header -->
                        <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                                                <ContentPresenter
                            ContentSource="Header"
                            VerticalAlignment="Center"/>
                        </Border>


                        <!-- Pop-out header -->
                        <Popup x:Name="HeaderPopup"
                               Placement="Right"
                               AllowsTransparency="True"
                               IsOpen="False"
                               PopupAnimation="Fade">
                            <Border Background="{StaticResource DarkBrush}"
                                    Padding="8,4"
                                    CornerRadius="4">
                                <!-- AccessText preserves _ and accessibility -->
                                <AccessText Text="{TemplateBinding Header}"
                                            Foreground="White"/>
                            </Border>
                        </Popup>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <!-- Mouse -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="HeaderPopup"
                                    Property="IsOpen"
                                    Value="True"/>
                            <Setter TargetName="Bd"
                                Property="Background"
                                Value="{StaticResource MenuHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd"
                                    Property="Background"
                                    Value="{StaticResource MenuPressBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                        <!-- Keyboard navigation parity -->
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="HeaderPopup"
                                    Property="IsOpen"
                                    Value="True"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- Combo Box -->
    <Style x:Key="DarkComboBox"
       TargetType="ComboBox">
        <Setter Property="Foreground"
            Value="{StaticResource LightBrush}"/>
        <Setter Property="Background"
            Value="{StaticResource DarkBrush}"/>
        <Setter Property="BorderBrush"
            Value="{StaticResource DarkBrush}"/>
        <Setter Property="BorderThickness"
            Value="1"/>
        <Setter Property="Padding"
            Value="6,3"/>
        <Setter Property="SnapsToDevicePixels"
            Value="True"/>
        <Setter Property="OverridesDefaultStyle"
            Value="True"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <!-- Main box -->
                        <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="2">

                            <ToggleButton x:Name="MainToggleButton"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          HorizontalContentAlignment="Stretch"
                                          VerticalContentAlignment="Stretch"
                                          OverridesDefaultStyle="True">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderThickness="0">
                                            <ContentPresenter HorizontalAlignment="Stretch"
                                                              VerticalAlignment="Stretch"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource LightBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource DarkBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource DarkBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <DockPanel>
                                    <!-- Selected item -->
                                    <ContentPresenter Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      />
                                    <Path Data="M 0 0 L 4 4 L 8 0 Z"
                                          Fill="{TemplateBinding Foreground}"
                                          Width="8"
                                          Height="4"
                                          Margin="4,0"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"/>
                                </DockPanel>
                            </ToggleButton>
                        </Border>

                        <!-- Dropdown -->
                        <Popup x:Name="PART_Popup"
                           Placement="Bottom"
                           IsOpen="{TemplateBinding IsDropDownOpen}"
                           AllowsTransparency="True"
                           Focusable="False">
                            <Border Background="{StaticResource DarkBrush}"
                                BorderBrush="{StaticResource DarkBrush}"
                                BorderThickness="1">
                                <ScrollViewer VerticalScrollBarVisibility="Disabled"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DarkComboBoxItem"
       TargetType="ComboBoxItem">
        <Setter Property="Foreground"
            Value="{StaticResource DarkBrush}"/>
        <Setter Property="Background"
            Value="Transparent"/>

        <Style.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter Property="Background"
                    Value="{StaticResource LightBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- List View -->
    <Style TargetType="ListView" BasedOn="{StaticResource LightBg}">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="ScrollViewer.Background" Value="{StaticResource LightBrush}"/>
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ListViewItem">
                    <Setter Property="Background" Value="{StaticResource LightBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource LightBrush}" />
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource ItemHoverBrush}" />
                            <Setter Property="BorderBrush" Value="{StaticResource ItemHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{StaticResource ItemHoverBrush}" />
                            <Setter Property="BorderBrush" Value="{StaticResource ItemHoverBrush}" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ListView ScrollBar -->
    <Style TargetType="ScrollBar">
        <Setter Property="Width" Value="8"/>
        <Setter Property="Background" Value="{StaticResource ItemBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource ItemBrush}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="BorderThickness" Value="0"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="{StaticResource DarkBrush}">
                        <Track x:Name="PART_Track"
                           IsDirectionReversed="True">
                            <!-- Disable arrows -->
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageUpCommand"
                                              Opacity="0"
                                              IsHitTestVisible="False"/>
                            </Track.DecreaseRepeatButton>

                            <!-- Thumb -->
                            <Track.Thumb>
                                <Thumb x:Name="Thumb" Background="{TemplateBinding Foreground}">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                                
                            </Track.Thumb>

                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageDownCommand"
                                              Opacity="0"
                                              IsHitTestVisible="False"/>
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource ItemHoverBrush}"/>
                        </Trigger>

                        <Trigger SourceName="Thumb"
                             Property="IsDragging"
                             Value="True">
                            <Setter Property="Foreground" Value="{StaticResource ItemHoverBrush}"/>
                        </Trigger>

                        <Trigger Property="Orientation" Value="Horizontal">
                            <Setter Property="Height" Value="8"/>
                            <Setter Property="Width" Value="Auto"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


</ResourceDictionary>